{
  "name": "mowai",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "mowai",
      "version": "0.1.0",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=22"
      }
    },
    "node_modules/@mowai/arena": {
      "resolved": "packages/arena",
      "link": true
    },
    "node_modules/@mowai/arena-ui": {
      "resolved": "packages/arena-ui",
      "link": true
    },
    "node_modules/@mowai/cli": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/@mowai/participant-ui": {
      "resolved": "packages/participant-ui",
      "link": true
    },
    "node_modules/ws": {
      "version": "8.19.0",
      "resolved": "https://registry.npmjs.org/ws/-/ws-8.19.0.tgz",
      "integrity": "sha512-blAT2mjOEIi0ZzruJfIhb3nps74PRWTCz1IjglWEEpQl5XS/UNama6u2/rjFkDDouqr4L67ry+1aGIALViWjDg==",
