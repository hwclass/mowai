    },
    "packages/arena-ui": {
      "name": "@mowai/arena-ui",
      "version": "0.1.0"
    },
    "packages/cli": {
      "name": "@mowai/cli",
      "version": "0.1.0",
      "bin": {
        "mowai": "bin/mowai.mjs"
      }
    },
    "packages/participant-ui": {
      "name": "@mowai/participant-ui",
      "version": "0.1.0"
    }
  }
}
